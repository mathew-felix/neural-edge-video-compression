# Virtual Environments
venv/
.venv/
env/
.env

# Output & Data Directories
outputs/*
!outputs/.gitkeep
output/
data/*
!data/.gitkeep
models/*
!models/.gitkeep
experiments/
logs/
! DCVC

# Python Cache & Compiled Files
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
.Python

# Distribution & Build
build/
**/build/
dist/
**/dist/
*.egg-info/
.eggs/
*.egg
*.manifest
*.spec

# PyTest / Linting / Type Checking
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
.nox/

# Media & Archives
*.mp4
*.avi
*.mkv
*.mov
*.zip
*.tar.gz
*.tar
docs/figures/*.pdf

# Logs & Temporary Files
*.log
build_log.txt
tmp/
temp/

# IDE & OS specific
.vscode/
.idea/
*.sw[a-z]
*~
.DS_Store
Thumbs.db

# DCVC source tree: keep source files, ignore only generated artifacts.
!DCVC/
!DCVC/src/
!DCVC/src/**
DCVC/src/**/__pycache__/
DCVC/src/**/*.py[cod]
DCVC/src/**/*.pyd
DCVC/src/**/*.so
DCVC/src/**/build/
DCVC/src/**/dist/
DCVC/src/**/*.egg-info/
DCVC/src/**/*.egg-info/**
